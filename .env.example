# GitLab CE Docker Environment Configuration
# Rename this file to .env and modify as needed

# Domain Configuration
GITLAB_DOMAIN=gitlab.example.com

# Container Configuration
GITLAB_IMAGE=gitlab/gitlab-ce:latest

# SMTP Settings
GITLAB_SMTP_ENABLED=false
GITLAB_SMTP_ADDRESS=smtp.example.com
GITLAB_SMTP_PORT=587
GITLAB_SMTP_USER=user@example.com
GITLAB_SMTP_PASSWORD=password
GITLAB_SMTP_DOMAIN=example.com
GITLAB_SMTP_AUTHENTICATION=login
GITLAB_SMTP_ENABLE_STARTTLS_AUTO=true
GITLAB_SMTP_TLS=false

# Backup Configuration
GITLAB_BACKUP_KEEP_TIME=604800  # 7 days in seconds

# System Resource Limits
GITLAB_MEMORY_LIMIT=4g

# Security Settings
GITLAB_HTTPS_ENABLED=true
# Set to 'redirect_http_to_https' or 'http_to_https'
GITLAB_NGINX_REDIRECT=redirect_http_to_https

# Database Configuration
GITLAB_DB_ADAPTER=postgresql
GITLAB_DB_ENCODING=unicode
GITLAB_DB_POOL=10

# Redis Configuration
GITLAB_REDIS_PORT=6379
